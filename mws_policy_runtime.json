{
  "meta": {
    "policy_name": "MWS v2.9.9",
    "policy_version": "v2.9.9",
    "policy_family": "Titanium MWS",
    "last_updated": "2026-03-17"
  },
  "governance": {
    "reporting_baselines": {
      "active_benchmarks": [
        "SPY",
        "QQQ"
      ],
      "corr_anchor_ticker": "VTI",
      "corr_anchor_tickers": [
        "VTI",
        "QQQ"
      ],
      "chart_start_date": "2026-01-01"
    },
    "fixed_asset_prices": {
      "CASH": 1.0,
      "TREASURY_NOTE": {
        "price_type": "market",
        "fallback_price": 45000,
        "fallback_condition": "use_only_if_market_price_unavailable",
        "compliance_tolerance_pct": 0.03,
        "bucket_a_breach_if": "market_price × face_value < bucket_a_minimum_usd"
      }
    },
    "execution": {
      "max_turnover": 0.2,
      "max_turnover_stress": 0.22,
      "trade_order": {
        "sells_first": true
      },
      "funding_priority": {
        "use_cash_first": true,
        "cash_definition": [
          "CASH"
        ],
        "funding_invariant": "total_sells + cash_used == total_buys",
        "cash_used_rule": "cash_used = min(cash_available, total_buys)",
        "residual_allocation_rule": {
          "priority_order": [
            "1. Underweight high-momentum inducted tickers — sorted by momentum score descending, up to each ticker's max_total cap. A ticker qualifies if: (a) current weight < target weight computed from percentile_in_band mapping, AND (b) momentum_score > 0.",
            "2. VTI — receives any residual not absorbed by step 1, up to its max_total cap.",
            "3. Cash — if step 2 is also fully capped, residual stays as cash."
          ],
          "constraint": "Residual allocation must still satisfy all per-ticker caps, sleeve caps, and L1 caps. If a high-momentum ticker is at its max_total, it is skipped in step 1."
        }
      },
      "max_turnover_window": "per_rebalance_event",
      "max_turnover_annualized": 0.6,
      "turnover_reporting": {
        "turnover_clipped_by_annual_cap": false,
        "turnover_clipped_by_event_cap": false
      },
      "trigger_precedence": {
        "order": [
          {
            "priority": 1,
            "trigger": "drawdown_rules.hard_limit",
            "action": "reduce_all_positions_toward_sleeve_floors_subject_to_min_total_with_hard_limit_override_if_insufficient",
            "overrides": "all_lower_priority_triggers",
            "turnover_cap_exemption": true
          },
          {
            "priority": 2,
            "trigger": "validators.bucket_a_minimum",
            "action": "halt_all_buys_restore_bucket_a",
            "overrides": "priorities_3_through_5"
          },
          {
            "priority": 3,
            "trigger": "validators.l1_sleeve_caps OR validators.l2_sleeve_caps OR validators.l2_sleeve_floors OR validators.per_ticker_caps OR validators.per_ticker_floors OR validators.ai_tech_breadth_floor_transition",
            "action": "enforce_cap_floor_compliance_sells_first",
            "overrides": "priorities_4_through_5"
          },
          {
            "priority": 4,
            "trigger": "validators.turnover_limit",
            "action": "clip_rebalance_to_turnover_cap_set_reporting_flag",
            "overrides": "priority_5"
          },
          {
            "priority": 5,
            "trigger": "rebalance_triggers.signal_drift OR rebalance_triggers.band_breach OR rebalance_triggers.calendar",
            "action": "execute_momentum_driven_rebalance",
            "overrides": "none"
          }
        ]
      }
    },
    "lifecycle_rules": {
      "review_days_default": 30,
      "stages": {
        "reference": {
          "eligible_for_momentum": false,
          "eligible_for_allocation": false,
          "requires_review": false
        },
        "inducted": {
          "eligible_for_momentum": true,
          "eligible_for_allocation": true,
          "requires_review": true
        },
        "activated": {
          "eligible_for_momentum": false,
          "eligible_for_allocation": false,
          "requires_review": true
        },
        "overlay": {
          "eligible_for_momentum": false,
          "eligible_for_allocation": false,
          "requires_review": true
        }
      },
      "transitions": {
        "reference_to_inducted": {
          "requires": [
            "manual_approval",
            "observation_period_days: 30",
            "positive_momentum_blend_consecutive_days: 15"
          ],
          "review_days": 30
        },
        "inducted_to_reference": {
          "triggers": [
            "blend_score_negative_consecutive_days: 20",
            "manual_demotion"
          ],
          "exit_rule": "reduce_to_zero_over_N_rebalance_cycles",
          "exit_cycles": 2
        },
        "inducted_dormant": {
          "condition": "lifecycle.stage == inducted AND current_weight == 0",
          "re_entry_trigger": {
            "momentum_blend_positive_consecutive_days": 15,
            "vix_below": 28,
            "vix_trend_clause": "TBD_round3: add VIX_5d_MA < VIX_20d_MA as alternative gate"
          },
          "initial_weight": "sleeve_floor_minimum"
        },
        "any_to_activated": {
          "triggers": [
            "manual_review_flag",
            "compliance_hold"
          ],
          "effect": "eligible_for_momentum: false, eligible_for_allocation: false"
        }
      }
    },
    "reference_tickers": [
      "AGG"
    ],
    "defaults": {
      "merge_order": [
        "governance.defaults.ticker_constraints",
        "ticker_constraints.<TICKER>"
      ],
      "ticker_constraints": {
        "lifecycle": {
          "stage": "reference"
        },
        "exclude_from_momentum": true,
        "exclude_from_denominator": true
      },
      "portfolio_accounting": {
        "sleeve_exposure_source": "ticker_to_sleeves_only",
        "unmapped_ticker_behavior": "exclude_from_sleeve_caps_and_floors",
        "exclude_overlays_from_sleeves": true,
        "overlay_reporting_mode": "separate_sleeve_tree",
        "overlay_l1_name": "stabilizers"
      }
    },
    "rebalance_triggers": {
      "calendar": {
        "enabled": true,
        "rule": "first_monday_of_month"
      },
      "band_breach": {
        "enabled": true,
        "hold_days_before_trigger": 3,
        "applies_to": [
          "l2_sleeves",
          "per_ticker_caps",
          "overlay_bands"
        ]
      },
      "signal_drift": {
        "enabled": true,
        "sleeve_drift_threshold": 0.05,
        "sleeve_drift_units": "abs_weight_delta_pct_points",
        "ticker_drift_threshold": 0.015,
        "ticker_drift_units": "abs_weight_delta_pct_points"
      },
      "stress_override": {
        "enabled": true,
        "condition": "drawdown_rules.soft_limit_breached == true",
        "action": "freeze_new_buys"
      }
    }
  },
  "allocation": {
    "denominator_mode": "allocatable_ex_bucket_a",
    "band_normalization": "percentile_in_band",
    "denominator_definition": "Allocatable denominator = TPV minus overlays (DBMF, KMLM) minus Bucket A (TREASURY_NOTE). Cash (Bucket B) IS included. Used as basis for all L1/L2 sleeve cap calculations.",
